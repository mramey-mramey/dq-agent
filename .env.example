# ── Copy this file to .env and fill in your values ───────────────────────────
# Never commit .env to source control.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── FastAPI backend ────────────────────────────────────────────────────────────
# URL Streamlit uses to reach the backend
BACKEND_URL=http://localhost:8001

# ── File I/O ──────────────────────────────────────────────────────────────────
# Where uploaded files land temporarily (created automatically if missing)
UPLOAD_DIR=/tmp/dq_uploads

# Where exported clean files are written (created automatically if missing)
OUTPUT_DIR=/tmp/dq_outputs

# ── Agent tuning ──────────────────────────────────────────────────────────────
# Maximum rows per ingest run (default 50,000)
DQ_MAX_RECORDS_PER_RUN=50000

# Fuzzy confidence below which issues are flagged only, not auto-proposed (0–1)
DQ_CONFIDENCE_THRESHOLD=0.80

# Confidence above which issues are eligible for bulk approval (0–1)
DQ_BULK_APPROVE_THRESHOLD=0.95

# Standard deviations from mean to flag outliers
DQ_OUTLIER_SIGMA=3.0

# ── Streamlit defaults ────────────────────────────────────────────────────────
DEFAULT_ROLE=analyst
DEFAULT_USER=analyst@yourorg.com

# ── Railway deployment (set automatically by Railway, listed here for reference)
# PORT=8000                      # Railway injects $PORT
# RAILWAY_ENVIRONMENT=production
